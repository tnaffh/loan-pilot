# Copy to deploy/.env and fill in real values before deploying.
# This single file feeds both docker-compose interpolation and the API container.

# --- Postgres ---------------------------------------------------------------
POSTGRES_USER=loanpilot
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password
POSTGRES_DB=loanpilot
# The API connects over the compose network to the "postgres" service.
DATABASE_URL=postgresql://loanpilot:CHANGE_ME_strong_db_password@postgres:5432/loanpilot?schema=public

# --- API --------------------------------------------------------------------
# REQUIRED: a long random string. The API refuses to start in production otherwise.
JWT_SECRET=CHANGE_ME_long_random_secret
# Public browser origins allowed by CORS (your web + dashboard domains).
CORS_ORIGINS=https://loanpilot.example.com,https://app.loanpilot.example.com
DEFAULT_TENANT_SLUG=rfs
# Public origin of the API itself (used for local-driver file URLs).
PUBLIC_API_ORIGIN=https://api.loanpilot.example.com

# --- Document storage (S3 / Cloudflare R2) ----------------------------------
STORAGE_DRIVER=s3
S3_BUCKET=loanpilot-documents
S3_REGION=auto
# R2/MinIO endpoint (leave blank for AWS S3, e.g. https://<acct>.r2.cloudflarestorage.com).
S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
S3_ACCESS_KEY_ID=CHANGE_ME
S3_SECRET_ACCESS_KEY=CHANGE_ME
# Optional: public bucket base URL. If blank, the API serves short-lived presigned URLs.
S3_PUBLIC_URL=

# --- Frontend build-time config ---------------------------------------------
# Browser-reachable API base (note the /api suffix). Inlined into the web/dashboard bundles.
NEXT_PUBLIC_API_URL=https://api.loanpilot.example.com/api

# --- Host port mappings (optional overrides) --------------------------------
API_PORT=4000
WEB_PORT=3000
DASHBOARD_PORT=3001
