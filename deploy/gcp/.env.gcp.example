# LoanPilot — GCP (Cloud Run) configuration reference.
#
# This file documents every runtime value the deployed services use and WHERE it
# lives. On GCP these are NOT loaded from a .env file — they are set on the Cloud
# Run services (env vars) and Secret Manager (secrets), wired by
# deploy/gcp/cloudbuild.yaml. This file is a human reference only; never commit
# real secret values.

# =============================================================================
# Cloud Build substitutions (pass via --substitutions or the trigger config)
# =============================================================================
_REGION=africa-south1
_REPO=loanpilot
_API_DOMAIN=api.raccoonsfinance.com
_CORS_ORIGINS=https://raccoonsfinance.com,https://www.raccoonsfinance.com,https://pilot.raccoonsfinance.com
_RUNTIME_SA=loanpilot-api@PROJECT_ID.iam.gserviceaccount.com
_INSTANCE=PROJECT_ID:africa-south1:loanpilot-db
_BUCKET=PROJECT_ID-loanpilot-documents

# =============================================================================
# API service — plain env vars (set by cloudbuild deploy-api step)
# =============================================================================
NODE_ENV=production
PORT=4000
CORS_ORIGINS=https://raccoonsfinance.com,https://www.raccoonsfinance.com,https://pilot.raccoonsfinance.com
PUBLIC_API_ORIGIN=https://api.raccoonsfinance.com
DEFAULT_TENANT_SLUG=rfs
# Document storage: native GCS, keyless (authenticates as the runtime service account).
STORAGE_DRIVER=gcs
GCS_BUCKET=PROJECT_ID-loanpilot-documents
# Leave unset to serve short-lived V4 signed URLs (correct for private PII docs).
# Set only if the bucket is public behind a CDN domain.
# GCS_PUBLIC_URL=
# Cloud Run's working dir is read-only; uploads (unused with gcs) must point at /tmp.
UPLOAD_DIR=/tmp/uploads
# Auth — where invite/reset links and the OAuth callback redirect to.
DASHBOARD_URL=https://pilot.raccoonsfinance.com
# Google sign-in: staff are invite-only AND must be on one of these domains.
OAUTH_ALLOWED_DOMAINS=raccoonsfinance.com,alphanumeric.com.na
# Empty disables Google login (password login still works). Set once the OAuth client exists.
GOOGLE_CLIENT_ID=
# OAUTH_CALLBACK_URL defaults to ${PUBLIC_API_ORIGIN}/api/auth/google/callback.
# Email (Resend). MAIL_FROM must be on the domain verified in Resend
# (here the sending subdomain send.raccoonsfinance.com).
MAIL_FROM=LoanPilot <no-reply@send.raccoonsfinance.com>

# =============================================================================
# API service — SECRETS (Secret Manager; mounted via --set-secrets)
# =============================================================================
# loanpilot-jwt-secret             -> JWT_SECRET            (strong random; API refuses to boot without it)
# loanpilot-db-url                 -> DATABASE_URL          (Cloud SQL Unix-socket form below)
# loanpilot-google-client-secret   -> GOOGLE_CLIENT_SECRET  (Google OAuth client secret; placeholder ok until Google is enabled)
# loanpilot-resend-key             -> RESEND_API_KEY        (Resend API key)
# DATABASE_URL=postgresql://loanpilot:PASSWORD@localhost/loanpilot?host=/cloudsql/PROJECT_ID:africa-south1:loanpilot-db&schema=public

# =============================================================================
# Front-end services (web + dashboard) — BUILD-TIME only
# =============================================================================
# Inlined into the bundles by the Docker --build-arg; not a runtime var.
NEXT_PUBLIC_API_URL=https://api.raccoonsfinance.com/api

# =============================================================================
# Public hostnames (Cloud Run domain mappings — see docs/DEPLOYMENT-GCP.md)
# =============================================================================
# raccoonsfinance.com        -> loanpilot-web        (apply / marketing)
# www.raccoonsfinance.com    -> redirect to apex
# pilot.raccoonsfinance.com  -> loanpilot-dashboard  (lender portal)
# api.raccoonsfinance.com    -> loanpilot-api
