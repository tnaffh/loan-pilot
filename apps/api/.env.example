# Copy to .env and adjust as needed.

# Runtime ---------------------------------------------------------------------
NODE_ENV=development
PORT=4000
DATABASE_URL="postgresql://loanpilot:loanpilot@localhost:5544/loanpilot?schema=public"
# Comma-separated list of allowed browser origins (web + dashboard).
CORS_ORIGINS="http://localhost:3000,http://localhost:3001"
# Slug of the tenant that the public marketing/apply site submits to.
DEFAULT_TENANT_SLUG="rfs"

# Auth ------------------------------------------------------------------------
# REQUIRED in production — the server refuses to start with this dev default.
JWT_SECRET="loanpilot-dev-secret-change-me"

# Document storage ------------------------------------------------------------
# STORAGE_DRIVER=local keeps files on disk (served from /uploads); use s3 in prod.
STORAGE_DRIVER=local
# Where local-driver files live, and the origin used to build their public URLs.
UPLOAD_DIR=uploads
PUBLIC_API_ORIGIN="http://localhost:4000"

# S3 / R2 (only when STORAGE_DRIVER=s3) ---------------------------------------
S3_BUCKET=""
S3_REGION="auto"
# Custom endpoint for Cloudflare R2 / MinIO (leave blank for AWS S3).
S3_ENDPOINT=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
# Optional: public bucket base URL. If unset, short-lived presigned URLs are used.
S3_PUBLIC_URL=""
