// LoanPilot — multi-tenant micro-lending schema.
// Every tenant-scoped row carries tenantId; isolate queries on it in services.
// All monetary fields are integer Namibian Dollar (N$) cents.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PlanId {
  starter
  growth
  pro
}

enum TenantStatus {
  active
  trial
  suspended
}

enum UserRole {
  platform
  lender_admin
  lender_staff
  borrower
}

enum UserStatus {
  active
  invited
  disabled
}

enum LoanType {
  payday
  business
  collateral
}

enum LoanStatus {
  active
  arrears
  partly_paid
  settled
  written_off
  cancelled
  closed
}

enum CollexiaStatus {
  pending
  loaded
  manual
}

enum PaymentMethod {
  eft
  cash
  debit_order
  deposit
  ewallet
  payroll
  revolved
}

enum ExpenseKind {
  expense
  drawing
}

enum ApplicationStatus {
  pending
  review
  approved
  declined
}

enum AffordabilityResult {
  pass
  review
  fail
}

enum RepaymentStatus {
  paid
  due
  overdue
}

enum InvoiceStatus {
  paid
  overdue
  pending
}

enum EmploymentType {
  permanently_employed
  civil_servant
  self_employed
  contract
  pensioner
}

model Tenant {
  id        String       @id @default(cuid())
  slug      String       @unique
  name      String
  short     String
  accent    String       @default("#25397a")
  plan      PlanId       @default(starter)
  status    TenantStatus @default(trial)
  town      String?
  logoUrl   String?
  joinedAt  DateTime     @default(now())
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  users        User[]
  borrowers    Borrower[]
  loans        Loan[]
  applications LoanApplication[]
  invoices     Invoice[]
  payments     Payment[]
  expenses     Expense[]
  investments  Investment[]
  incomes      Income[]
  auditEvents  AuditEvent[]
  settings     TenantSettings?
  products     LoanProduct[]
  roles        Role[]
}

/**
 * Per-lender fee configuration applied to every loan. Levy and insurance rates
 * are fractions of the loan amount; stamp duty and the insurance flat component
 * are integer N$ cents. One row per tenant (created lazily on first read).
 */
model TenantSettings {
  id              String   @id @default(cuid())
  tenantId        String   @unique
  tenant          Tenant   @relation(fields: [tenantId], references: [id])
  // NAMFISA levy as a fraction of the loan amount (0.0103 = 1.03%); remitted annually.
  namfisaLevyRate Float    @default(0.0103)
  // Flat stamp duty in cents (default N$5).
  stampDuty       Int      @default(500)
  // Insurance as a fraction of the loan amount (0 = off).
  insuranceRate   Float    @default(0)
  // Flat insurance component in cents (0 = off).
  insuranceFlat   Int      @default(0)
  // Monthly compounding rate for term-loan growth (months 2..n) and default
  // interest on overdue instalments. NAMFISA cap is 5%.
  monthlyRate     Float    @default(0.05)
  // Opening/bank balance (cents) so the computed available balance reconciles to
  // the lender's actual bank account.
  openingBalance  Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

/**
 * A named interest-rate plan ("product"). Carries the flat finance-charge rate
 * applied to the principal debt, including promotional rates (e.g. 0.25, or 0
 * for an interest-free loan). Deactivate rather than delete to keep history.
 */
model LoanProduct {
  id           String    @id @default(cuid())
  tenantId     String
  tenant       Tenant    @relation(fields: [tenantId], references: [id])
  name         String
  // Optional restriction to a single loan type; null = any.
  loanType     LoanType?
  interestRate Float
  active       Boolean   @default(true)
  // The product seeded when none is chosen (e.g. the public application flow).
  isDefault    Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  loans Loan[]

  @@index([tenantId])
}

/** Append-only change log for data corrections (borrower/loan edits, cancel). */
model AuditEvent {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  // Denormalised so the trail survives the actor being deleted.
  actorId   String?
  actorName String
  entity    String // 'borrower' | 'loan'
  entityId  String
  action    String // 'updated' | 'cancelled' | 'address_updated' | 'bank_updated'
  changes   Json // [{ field, from, to }]
  createdAt DateTime @default(now())

  @@index([tenantId, entity, entityId])
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  // Null for OAuth-only users or those who haven't accepted an invite yet.
  passwordHash String?
  name         String
  role         UserRole   @default(lender_staff)
  status       UserStatus @default(active)
  image        String?
  // platform-operator users are not tied to a tenant
  tenantId     String?
  tenant       Tenant?    @relation(fields: [tenantId], references: [id])
  // when role = borrower, link to the borrower profile
  borrowerId   String?    @unique
  borrower     Borrower?  @relation(fields: [borrowerId], references: [id])
  // Custom role carrying granular permissions (lender users; null for platform/borrower).
  roleId       String?
  customRole   Role?      @relation(fields: [roleId], references: [id])
  invitedById  String?
  // Single-use, hashed tokens (sha256) for invite acceptance and password reset.
  inviteTokenHash String?
  inviteExpiresAt DateTime?
  resetTokenHash  String?
  resetExpiresAt  DateTime?
  lastLoginAt  DateTime?
  accounts     AuthAccount[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([tenantId])
  @@index([roleId])
}

model Role {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  name      String
  // Fixed catalog keys from @loan-pilot/domain; validated in the service, not the DB.
  permissions String[] @default([])
  // Built-in roles (administrator | staff) seeded per tenant; can't be deleted/renamed.
  isSystem  Boolean  @default(false)
  // 'administrator' | 'staff' for system roles; null for custom roles.
  key       String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users User[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

/** A linked external identity provider (e.g. Google) for a user. */
model AuthAccount {
  id                String   @id @default(cuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider          String
  providerAccountId String
  createdAt         DateTime @default(now())

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Borrower {
  id             String         @id @default(cuid())
  tenantId       String
  tenant         Tenant         @relation(fields: [tenantId], references: [id])
  firstName      String
  lastName       String
  idNumber       String
  phone          String
  email          String
  employer       String
  occupation     String
  monthlyIncome  Int
  employmentType EmploymentType
  gender         String?
  // Salary pay day; kept as the raw sheet value (e.g. "25" or "25/10/23").
  payDay         String?
  // Collexia debt-order client reference; unique per tenant, set after loading.
  collexiaClientNo String?
  status         String         @default("active")
  since          DateTime       @default(now())
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  loans        Loan[]
  user         User?
  addresses    BorrowerAddress[]
  bankAccounts BorrowerBankAccount[]
  documents    Document[]

  @@unique([tenantId, idNumber])
  @@unique([tenantId, collexiaClientNo])
  @@index([tenantId])
}

model BorrowerAddress {
  id         String   @id @default(cuid())
  borrowerId String
  borrower   Borrower @relation(fields: [borrowerId], references: [id], onDelete: Cascade)
  // Optional label, e.g. "Residential" / "Postal" / "Work".
  label      String?
  street     String
  suburb     String?
  city       String
  region     String?
  country    String   @default("Namibia")
  // Exactly one active address per borrower (enforced by a partial unique index).
  isActive   Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([borrowerId])
}

model BorrowerBankAccount {
  id                String   @id @default(cuid())
  borrowerId        String
  borrower          Borrower @relation(fields: [borrowerId], references: [id], onDelete: Cascade)
  bankName          String
  accountNumber     String
  branchName        String?
  branchCode        String?
  accountHolderName String
  accountType       String
  // Exactly one active account per borrower (enforced by a partial unique index).
  isActive          Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([borrowerId])
}

model Loan {
  id               String     @id @default(cuid())
  tenantId         String
  tenant           Tenant     @relation(fields: [tenantId], references: [id])
  borrowerId       String
  borrower         Borrower   @relation(fields: [borrowerId], references: [id])
  type             LoanType
  principal        Int
  financeCharge    Int
  // Per-loan regulatory / transaction fees (cents). Defaulted to 0 for loans
  // priced before these were tracked.
  bankCharges      Int        @default(0)
  namfisaLevy      Int        @default(0)
  stampDuty        Int        @default(0)
  insurance        Int        @default(0)
  // Flat finance-charge rate applied to the principal debt (e.g. 0.3 = 30%).
  interestRate     Float      @default(0.3)
  // The rate plan this loan was priced from, if any.
  productId        String?
  product          LoanProduct? @relation(fields: [productId], references: [id])
  total            Int
  termMonths       Int
  instalment       Int
  instalmentsPaid  Int        @default(0)
  instalmentsTotal Int
  balance          Int
  status           LoanStatus @default(active)
  collateral       String?
  daysLate         Int        @default(0)
  // Reporting bucket from the source register, e.g. "October 2023".
  originMonth      String?
  // Stable key from the source register ("October 2023#1"); enables idempotent import.
  externalRef      String?
  // Free-text provenance/admin note (e.g. marks reconstructed historical loans).
  note             String?
  // Reason captured when a loan is written off as bad debt.
  writeOffReason   String?
  // Reason captured when a payment-free loan is cancelled (error / fell through).
  cancelReason     String?
  disbursedAt      DateTime?
  nextDueAt        DateTime?
  // When the loan left the active book (settled or written off).
  closedAt         DateTime?
  // Operational payout confirmation: whether the funds have physically left the
  // lender's account (separate from approval — a loan can be approved first).
  fundsReleased    Boolean    @default(false)
  fundsReleasedAt  DateTime?
  // Collexia debt-order loading state (reminder to load disbursed loans).
  collexiaStatus   CollexiaStatus @default(pending)
  collexiaMarkedAt DateTime?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  schedule RepaymentScheduleItem[]
  payments Payment[]

  @@unique([tenantId, externalRef])
  @@index([tenantId])
  @@index([borrowerId])
}

model RepaymentScheduleItem {
  id     String          @id @default(cuid())
  loanId String
  loan   Loan            @relation(fields: [loanId], references: [id], onDelete: Cascade)
  number Int
  dueAt  DateTime
  amount Int
  status RepaymentStatus @default(due)
  paidAt DateTime?

  @@unique([loanId, number])
  @@index([loanId])
}

model LoanApplication {
  id             String              @id @default(cuid())
  tenantId       String
  tenant         Tenant              @relation(fields: [tenantId], references: [id])
  firstName      String
  lastName       String
  idNumber       String
  dateOfBirth    String
  phone          String
  email          String
  // Structured residential address snapshot (becomes the borrower's active address on approval).
  addrStreet     String
  addrSuburb     String?
  addrCity       String
  addrRegion     String?
  addrCountry    String              @default("Namibia")
  maritalStatus  String?
  type           LoanType
  amount         Int
  termMonths     Int
  purpose        String?
  declaredIncome Int
  employmentType EmploymentType
  employer       String
  occupation     String
  // Full bank-account snapshot (becomes the borrower's active account on approval).
  bankName          String
  bankAccountNumber String
  bankBranchName    String?
  bankBranchCode    String?
  bankAccountHolder String
  accountType       String
  // server-computed quote + assessment
  quotedTotal       Int
  quotedInstalment  Int
  affordabilityRatio Float
  status         ApplicationStatus   @default(pending)
  affordability  AffordabilityResult @default(review)
  // Reason captured when an application is declined; shown in its activity timeline.
  declineReason  String?
  // When the application was last moved (to review / approved / declined).
  decidedAt      DateTime?
  submittedAt    DateTime            @default(now())
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  references ApplicationReference[]
  documents  Document[]

  @@index([tenantId])
  @@index([status])
}

model ApplicationReference {
  id            String          @id @default(cuid())
  applicationId String
  application   LoanApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  name          String
  phone         String

  @@index([applicationId])
}

model Document {
  id            String           @id @default(cuid())
  applicationId String?
  application   LoanApplication? @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  // Documents attach to a borrower (directly, or relinked from the application on
  // approval) so they persist across the borrower's loans.
  borrowerId    String?
  borrower      Borrower?        @relation(fields: [borrowerId], references: [id], onDelete: Cascade)
  kind          String
  url           String
  fileName      String
  mimeType      String?
  sizeBytes     Int?
  uploadedAt    DateTime         @default(now())

  @@index([applicationId])
  @@index([borrowerId])
}

model Invoice {
  id          String        @id @default(cuid())
  tenantId    String
  tenant      Tenant        @relation(fields: [tenantId], references: [id])
  description String
  plan        PlanId?
  amount      Int
  status      InvoiceStatus @default(pending)
  issuedAt    DateTime      @default(now())

  @@index([tenantId])
}

// An actual payment received against a loan (distinct from the scheduled
// RepaymentScheduleItem). Amounts are integer N$ cents.
model Payment {
  id          String        @id @default(cuid())
  tenantId    String
  tenant      Tenant        @relation(fields: [tenantId], references: [id])
  loanId      String
  loan        Loan          @relation(fields: [loanId], references: [id], onDelete: Cascade)
  paidAt      DateTime
  amount      Int
  method      PaymentMethod @default(cash)
  badDebt     Boolean       @default(false)
  // Stable key from the source register; enables idempotent import.
  externalRef String?
  note        String?
  createdAt   DateTime      @default(now())

  @@unique([tenantId, externalRef])
  @@index([tenantId])
  @@index([loanId])
}

// An operating expense (or an owner drawing/dividend) for the lender. Amounts
// are integer N$ cents.
model Expense {
  id          String      @id @default(cuid())
  tenantId    String
  tenant      Tenant      @relation(fields: [tenantId], references: [id])
  kind        ExpenseKind @default(expense)
  category    String
  // Raw month label from the source register, e.g. "Dec 2023" or "August".
  period      String?
  incurredAt  DateTime?
  amount      Int
  // Stable key from the source register; enables idempotent import.
  externalRef String?
  note        String?
  createdAt   DateTime    @default(now())

  @@unique([tenantId, externalRef])
  @@index([tenantId])
}

// Capital injected into the cash-loan book by the owners (the "Additional
// Investment" register). Financing, not income — excluded from P&L. Amounts are
// integer N$ cents.
model Investment {
  id            String    @id @default(cuid())
  tenantId      String
  tenant        Tenant    @relation(fields: [tenantId], references: [id])
  name          String
  // Raw label from the source register; the year is often absent there.
  period        String?
  contributedAt DateTime?
  amount        Int
  // Stable key from the source register; enables idempotent import.
  externalRef   String?
  note          String?
  createdAt     DateTime  @default(now())

  @@unique([tenantId, externalRef])
  @@index([tenantId])
}

// Operational income received that is not a loan repayment or owner capital
// (e.g. recoveries, admin fees, other income). Feeds available balance. Amounts
// are integer N$ cents.
model Income {
  id          String    @id @default(cuid())
  tenantId    String
  tenant      Tenant    @relation(fields: [tenantId], references: [id])
  category    String
  period      String?
  incurredAt  DateTime?
  amount      Int
  externalRef String?
  note        String?
  createdAt   DateTime  @default(now())

  @@unique([tenantId, externalRef])
  @@index([tenantId])
}
