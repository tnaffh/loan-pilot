// LoanPilot — multi-tenant micro-lending schema.
// Every tenant-scoped row carries tenantId; isolate queries on it in services.
// All monetary fields are integer Namibian Dollar (N$) cents.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PlanId {
  starter
  growth
  pro
}

enum TenantStatus {
  active
  trial
  suspended
}

enum UserRole {
  platform
  lender_admin
  lender_staff
  borrower
}

enum LoanType {
  payday
  business
  collateral
}

enum LoanStatus {
  active
  arrears
  partly_paid
  settled
  written_off
  closed
}

enum PaymentMethod {
  eft
  cash
  debit_order
  deposit
  ewallet
  payroll
  revolved
}

enum ExpenseKind {
  expense
  drawing
}

enum ApplicationStatus {
  pending
  review
  approved
  declined
}

enum AffordabilityResult {
  pass
  review
  fail
}

enum RepaymentStatus {
  paid
  due
  overdue
}

enum InvoiceStatus {
  paid
  overdue
  pending
}

enum EmploymentType {
  permanently_employed
  civil_servant
  self_employed
  contract
  pensioner
}

model Tenant {
  id        String       @id @default(cuid())
  slug      String       @unique
  name      String
  short     String
  accent    String       @default("#25397a")
  plan      PlanId       @default(starter)
  status    TenantStatus @default(trial)
  town      String?
  logoUrl   String?
  joinedAt  DateTime     @default(now())
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  users        User[]
  borrowers    Borrower[]
  loans        Loan[]
  applications LoanApplication[]
  invoices     Invoice[]
  payments     Payment[]
  expenses     Expense[]
  investments  Investment[]
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  name         String
  role         UserRole  @default(lender_staff)
  // platform-operator users are not tied to a tenant
  tenantId     String?
  tenant       Tenant?   @relation(fields: [tenantId], references: [id])
  // when role = borrower, link to the borrower profile
  borrowerId   String?   @unique
  borrower     Borrower? @relation(fields: [borrowerId], references: [id])
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([tenantId])
}

model Borrower {
  id             String         @id @default(cuid())
  tenantId       String
  tenant         Tenant         @relation(fields: [tenantId], references: [id])
  firstName      String
  lastName       String
  idNumber       String
  phone          String
  email          String
  address        String
  employer       String
  occupation     String
  monthlyIncome  Int
  employmentType EmploymentType
  bank           String
  accountType    String
  gender         String?
  // Salary pay day; kept as the raw sheet value (e.g. "25" or "25/10/23").
  payDay         String?
  status         String         @default("active")
  since          DateTime       @default(now())
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  loans Loan[]
  user  User?

  @@unique([tenantId, idNumber])
  @@index([tenantId])
}

model Loan {
  id               String     @id @default(cuid())
  tenantId         String
  tenant           Tenant     @relation(fields: [tenantId], references: [id])
  borrowerId       String
  borrower         Borrower   @relation(fields: [borrowerId], references: [id])
  type             LoanType
  principal        Int
  financeCharge    Int
  // Per-loan regulatory / transaction fees (cents). Defaulted to 0 for loans
  // priced before these were tracked.
  bankCharges      Int        @default(0)
  namfisaLevy      Int        @default(0)
  stampDuty        Int        @default(0)
  // Flat finance-charge rate applied to the principal (e.g. 0.3 = 30%).
  interestRate     Float      @default(0.3)
  total            Int
  termMonths       Int
  instalment       Int
  instalmentsPaid  Int        @default(0)
  instalmentsTotal Int
  balance          Int
  status           LoanStatus @default(active)
  collateral       String?
  daysLate         Int        @default(0)
  // Reporting bucket from the source register, e.g. "October 2023".
  originMonth      String?
  // Stable key from the source register ("October 2023#1"); enables idempotent import.
  externalRef      String?
  // Free-text provenance/admin note (e.g. marks reconstructed historical loans).
  note             String?
  disbursedAt      DateTime?
  nextDueAt        DateTime?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  schedule RepaymentScheduleItem[]
  payments Payment[]

  @@unique([tenantId, externalRef])
  @@index([tenantId])
  @@index([borrowerId])
}

model RepaymentScheduleItem {
  id     String          @id @default(cuid())
  loanId String
  loan   Loan            @relation(fields: [loanId], references: [id], onDelete: Cascade)
  number Int
  dueAt  DateTime
  amount Int
  status RepaymentStatus @default(due)
  paidAt DateTime?

  @@unique([loanId, number])
  @@index([loanId])
}

model LoanApplication {
  id             String              @id @default(cuid())
  tenantId       String
  tenant         Tenant              @relation(fields: [tenantId], references: [id])
  firstName      String
  lastName       String
  idNumber       String
  dateOfBirth    String
  phone          String
  email          String
  address        String
  maritalStatus  String?
  type           LoanType
  amount         Int
  termMonths     Int
  purpose        String?
  declaredIncome Int
  employmentType EmploymentType
  employer       String
  occupation     String
  bank           String
  accountType    String
  // server-computed quote + assessment
  quotedTotal       Int
  quotedInstalment  Int
  affordabilityRatio Float
  status         ApplicationStatus   @default(pending)
  affordability  AffordabilityResult @default(review)
  submittedAt    DateTime            @default(now())
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  references ApplicationReference[]
  documents  Document[]

  @@index([tenantId])
  @@index([status])
}

model ApplicationReference {
  id            String          @id @default(cuid())
  applicationId String
  application   LoanApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  name          String
  phone         String

  @@index([applicationId])
}

model Document {
  id            String           @id @default(cuid())
  applicationId String?
  application   LoanApplication? @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  kind          String
  url           String
  uploadedAt    DateTime         @default(now())

  @@index([applicationId])
}

model Invoice {
  id          String        @id @default(cuid())
  tenantId    String
  tenant      Tenant        @relation(fields: [tenantId], references: [id])
  description String
  plan        PlanId?
  amount      Int
  status      InvoiceStatus @default(pending)
  issuedAt    DateTime      @default(now())

  @@index([tenantId])
}

// An actual payment received against a loan (distinct from the scheduled
// RepaymentScheduleItem). Amounts are integer N$ cents.
model Payment {
  id          String        @id @default(cuid())
  tenantId    String
  tenant      Tenant        @relation(fields: [tenantId], references: [id])
  loanId      String
  loan        Loan          @relation(fields: [loanId], references: [id], onDelete: Cascade)
  paidAt      DateTime
  amount      Int
  method      PaymentMethod @default(cash)
  badDebt     Boolean       @default(false)
  // Stable key from the source register; enables idempotent import.
  externalRef String?
  note        String?
  createdAt   DateTime      @default(now())

  @@unique([tenantId, externalRef])
  @@index([tenantId])
  @@index([loanId])
}

// An operating expense (or an owner drawing/dividend) for the lender. Amounts
// are integer N$ cents.
model Expense {
  id          String      @id @default(cuid())
  tenantId    String
  tenant      Tenant      @relation(fields: [tenantId], references: [id])
  kind        ExpenseKind @default(expense)
  category    String
  // Raw month label from the source register, e.g. "Dec 2023" or "August".
  period      String?
  incurredAt  DateTime?
  amount      Int
  // Stable key from the source register; enables idempotent import.
  externalRef String?
  note        String?
  createdAt   DateTime    @default(now())

  @@unique([tenantId, externalRef])
  @@index([tenantId])
}

// Capital injected into the cash-loan book by the owners (the "Additional
// Investment" register). Financing, not income — excluded from P&L. Amounts are
// integer N$ cents.
model Investment {
  id            String    @id @default(cuid())
  tenantId      String
  tenant        Tenant    @relation(fields: [tenantId], references: [id])
  name          String
  // Raw label from the source register; the year is often absent there.
  period        String?
  contributedAt DateTime?
  amount        Int
  // Stable key from the source register; enables idempotent import.
  externalRef   String?
  note          String?
  createdAt     DateTime  @default(now())

  @@unique([tenantId, externalRef])
  @@index([tenantId])
}
