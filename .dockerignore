# Dependencies & build output (rebuilt inside the image)
**/node_modules
**/dist
**/.next
**/.turbo
.turbo

# Version control & local tooling
.git
.github
.vscode
.idea

# Local env & secrets — never bake into an image
**/.env
**/.env.*
!**/.env.example

# Uploaded documents (use a volume / object storage instead)
apps/api/uploads/*
!apps/api/uploads/.gitkeep

# Misc
**/*.log
**/coverage
.DS_Store
deploy/.env
